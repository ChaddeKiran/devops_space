pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'chaddekiran/bookmycar_backend'
        DOCKER_TAG = "v1.0.${env.BUILD_NUMBER}"
        BRANCH_NAME = "${params.BRANCH_NAME}"
        AWS_REGION = 'ap-south-1'
        EKS_CLUSTER_NAME = 'Tf_project_cluster'
    }

    stages {

        stage('Checkout App Repo') {
            steps {
                dir('app') {
                    git branch: "${BRANCH_NAME}",
                        url: 'https://github.com/ChaddeKiran/BookMyCar.git',
                        credentialsId: 'GITHUB_CRED'
                }
            }
        }

        stage('Checkout DevOps Repo') {
            steps {
                dir('devops') {
                    git branch: 'main',
                        url: 'https://github.com/ChaddeKiran/devops_space.git',
                        credentialsId: 'GITHUB_CRED'
                }
            }
        }

        stage('Install') {
            steps {
                dir('app/backend-api') {
                    sh '''
                        chmod +x mvnw
                        ./mvnw clean install -DskipTests
                    '''
                }
            }
        }

        stage('Build') {
            steps {
                dir('app/backend-api') {
                    sh '''
                        docker build -t $DOCKER_IMAGE:$DOCKER_TAG .
                        docker tag $DOCKER_IMAGE:$DOCKER_TAG $DOCKER_IMAGE:latest
                    '''
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'DOCKERHUB_CRED',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        docker login -u $DOCKER_USERNAME -p $DOCKER_PASSWORD
                        docker push $DOCKER_IMAGE:$DOCKER_TAG
                        docker push $DOCKER_IMAGE:latest
                    '''
                }
            }
        }

        stage('Deployment to EKS') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'AWS_CRED'
                ]]) {
                    dir('devops') {
                        sh '''
                            aws eks --region $AWS_REGION update-kubeconfig --name $EKS_CLUSTER_NAME

                            kubectl apply -f backend/prod/deployments/deployment-blue.yaml

                            kubectl set image deployment/bookmycar-backend-blue \
                            backend=$DOCKER_IMAGE:$DOCKER_TAG \
                            --namespace=prod
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            sh '''
                docker rmi $DOCKER_IMAGE:$DOCKER_TAG || true
                docker rmi $DOCKER_IMAGE:latest || true
            '''
        }
        success {
            echo 'Deployment to EKS succeeded!'
        }
        failure {
            echo 'Pipeline failed. Check logs above.'
        }
    }
}